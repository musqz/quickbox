# ─── Quickget distro list updater ────────────────────────────────────────────

def _update_distro_list(parent_win):
    """Background thread to update ~/.config/quickbox/quickinst.csv from quickget --list"""
    import subprocess
    
    wait_win = None  # Initialize outside so it's available to all inner functions
    
    def run_update():
        nonlocal wait_win  # Allow modifying wait_win from nested scope
        try:
            # Run quickget --list in subprocess
            result = subprocess.run(["quickget", "--list"], 
                                  capture_output=True, text=True, timeout=60)
            
            if result.returncode != 0:
                GLib.idle_add(lambda: notify("Distro List", 
                                            f"✗ Error: {result.stderr[:100]}", "critical"))
                return
            
            # Parse output and build CSV: distro release [option] -> name,quickget cmd
            lines = result.stdout.strip().split('\n')
            csv_path = Path.home() / ".config/quickbox/quickinst.csv"
            csv_path.parent.mkdir(parents=True, exist_ok=True)
            
            csv_lines = []
            for i, line in enumerate(lines):
                line = line.strip()
                
                # Skip header (first line) and empty lines
                if i == 0 or not line:
                    continue
                
                # Parse space-separated: distro release [option]
                parts = line.split()
                if len(parts) >= 2:
                    # Build display name: capitalize distro, keep release/option as-is
                    distro = parts[0].capitalize()
                    rest = ' '.join(parts[1:])
                    display_name = f"{distro} {rest}".strip()
                    
                    # Build quickget command: lowercase, space-separated
                    cmd = f"quickget {' '.join(parts).lower()}"
                    
                    csv_lines.append(f"{display_name},{cmd}")
            
            if not csv_lines:
                GLib.idle_add(lambda: notify("Distro List", 
                                            "⚠ No distros found in output", "normal"))
                return
            
            # Write CSV - make sure we preserve the data
            try:
                csv_path.write_text('\n'.join(csv_lines) + '\n')
                GLib.idle_add(lambda: notify("Distro List", 
                                            f"✓ Updated {len(csv_lines)} distros", "low"))
            except Exception as e:
                GLib.idle_add(lambda: notify("Distro List", 
                                            f"✗ Failed to write CSV: {str(e)[:80]}", "critical"))
                
        except subprocess.TimeoutExpired:
            GLib.idle_add(lambda: notify("Distro List", 
                                        "✗ Timeout (>60s)", "critical"))
        except FileNotFoundError:
            GLib.idle_add(lambda: notify("Distro List", 
                                        "✗ quickget not found. Install quickemu.", "critical"))
        except Exception as e:
            GLib.idle_add(lambda: notify("Distro List", 
                                        f"✗ Error: {str(e)[:80]}", "critical"))
        finally:
            # Safely destroy wait_win
            if wait_win:
                GLib.idle_add(lambda: wait_win.destroy() if wait_win else None)
    
    # Create wait window (non-blocking)
    wait_win = Gtk.Window()
    wait_win.set_transient_for(parent_win)
    wait_win.set_modal(True)
    wait_win.set_decorated(False)
    wait_win.set_default_size(300, 80)
    
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
    box.set_margin_top(16)
    box.set_margin_bottom(16)
    box.set_margin_start(16)
    box.set_margin_end(16)
    
    lbl = Gtk.Label(label=S["distro_updating"])
    lbl.set_wrap(True)
    box.append(lbl)

    spinner = Gtk.Spinner()
    spinner.start()
    box.append(spinner)
    
    wait_win.set_child(box)
    wait_win.present()
    
    # Start update in background thread
    t = threading.Thread(target=run_update, daemon=True)
    t.start()


