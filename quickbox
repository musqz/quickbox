                    def _convert():
                        disk = str(dest_dir / "disk.qcow2")
                        try:
                            subprocess.run(["qemu-img", "convert", "-f", "raw", "-O", "qcow2",
                                             str(src_path), disk])
                            subprocess.run(["qemu-img", "resize", disk, "20G"])
                        finally:
                            flag.unlink(missing_ok=True)
                        notify("quickbox", S["ntf_vm_created"].format(vm_name), "low")
                        GLib.idle_add(self._refresh)
                        GLib.timeout_add(200, lambda: self._select_vm_by_name(dest_name) or False)
                    threading.Thread(target=_convert, daemon=True).start()
                else:
                    conf_text = (f"#!/usr/bin/quickemu --vm\n"
                                 f"guest_os=\"linux\"\n"
                                 f"disk_img=\"{dest_name}/disk.qcow2\"\n"
                                 f"iso=\"{dest_name}/{src_path.name}\"\n"
                                 f"pretty=\"{vm_name}\"\n"
                                 f"ssh_port=\"{ssh_port}\"\n")
                    dest_conf.write_text(conf_text)
                    dest_conf.chmod(0o755)
                    flag = Path(self.vms_dir) / f".{dest_name}.copying"
                    flag.write_text(str(src_path.stat().st_size))
                    self._refresh()
                    self._select_vm_by_name(dest_name)
                    notify("quickbox", S["ntf_copying"].format(src_path.name), "low")
                    def _copy():
