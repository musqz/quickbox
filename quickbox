        progress.set_show_text(False)
        box.append(progress)

        status_lbl = Gtk.Label(label=S["prog_wait"])
        status_lbl.set_halign(Gtk.Align.CENTER)
        status_lbl.add_css_class("dim-label")
        box.append(status_lbl)

        dlg.set_child(box)
        dlg.present()

        def _pulse():
            progress.pulse()
            return self._proc_running

        self._proc_running = True
        GLib.timeout_add(150, _pulse)

        def _run():
            try:
                proc = subprocess.run(
                    cmd_list, cwd=cwd,
                    capture_output=True, text=True
                )
                rc = proc.returncode
            except Exception:
                rc = 1

            self._proc_running = False

            if rc == 0:
                GLib.idle_add(progress.set_fraction, 1.0)
                GLib.idle_add(spinner.stop)
                GLib.idle_add(status_lbl.set_markup,
                    f'<span color="gray">{S["prog_done"]}</span>')
            else:
                GLib.idle_add(spinner.stop)
                GLib.idle_add(status_lbl.set_markup,
                    f'<span color="red">{S["prog_fail"]}</span>')

            def _finish():
                dlg.close()
                if on_done:
                    on_done(rc == 0)
            GLib.timeout_add(1200, _finish)

        threading.Thread(target=_run, daemon=True).start()

    def _pick_dir(self, title, start, callback):
        fc = Gtk.FileChooserNative(title=title,
                                   transient_for=self,
                                   action=Gtk.FileChooserAction.SELECT_FOLDER)
        initial = Gio.File.new_for_path(start)
        fc.set_current_folder(initial)
        def _on_response(chooser, response):
            if response == Gtk.ResponseType.ACCEPT:
                gfile = chooser.get_file()
                callback(gfile.get_path() if gfile else None)
            else:
                callback(None)
        fc.connect("response", _on_response)
        fc.show()

    def _confirm(self, title, body, callback):
        dlg = Gtk.AlertDialog()
        dlg.set_message(title)
        dlg.set_detail(body)
        dlg.set_buttons([S["btn_confirm_no"], S["btn_confirm_yes"]])
        dlg.set_default_button(0)
        dlg.set_cancel_button(0)
        def _on_response(d, result):
            try:
                idx = d.choose_finish(result)
                callback(idx == 1)
            except Exception:
                callback(False)
        dlg.choose(self, None, _on_response)

    def _confirm_danger(self, title, body, callback):
        win = Gtk.Window()
        win.set_title(title)
        win.set_transient_for(self)
        win.set_modal(True)
        win.set_resizable(False)
        win.set_default_size(420, -1)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_margin_top(24); outer.set_margin_bottom(16)
        outer.set_margin_start(24); outer.set_margin_end(24)

        title_lbl = Gtk.Label()
        title_lbl.set_markup(f'<b>{title}</b>')
        title_lbl.set_halign(Gtk.Align.START)
        title_lbl.set_margin_bottom(12)
        outer.append(title_lbl)

        body_lbl = Gtk.Label(label=body)
        body_lbl.set_halign(Gtk.Align.START)
        body_lbl.set_wrap(True)
        body_lbl.set_max_width_chars(52)
        body_lbl.set_margin_bottom(20)
        outer.append(body_lbl)

        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_box.set_halign(Gtk.Align.END)

        yes_btn = Gtk.Button(label=S["btn_delete_orig"])
        yes_btn.add_css_class("destructive-action")

        no_btn = Gtk.Button(label=S["btn_keep"])
        win.set_default_widget(no_btn)

        def _done(result):
            win.destroy()
            callback(result)

        no_btn.connect("clicked", lambda b: _done(False))
        yes_btn.connect("clicked", lambda b: _done(True))
        win.connect("close-request", lambda w: _done(False) or False)

        btn_box.append(yes_btn)
        btn_box.append(no_btn)
        outer.append(btn_box)

        win.set_child(outer)
        win.present()
        no_btn.grab_focus()

    def _warn(self, title, body):
        dlg = Gtk.AlertDialog()
        dlg.set_message(title)
        dlg.set_detail(body)
        dlg.set_buttons(["OK"])
        dlg.show(self)


