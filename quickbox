            if dest_dir.exists():
                self._warn(S["warn_exists_t"], S["warn_exists_b"].format(dest_name))
                return

            fc = Gtk.FileChooserNative(title=S["cvm_file_title"],
                                       transient_for=self,
                                       action=Gtk.FileChooserAction.OPEN)
