        info = Gtk.Label()
        info.set_markup(f'<span size="small" color="gray">{S["mig_hint"]}</span>')
        info.set_halign(Gtk.Align.START)
        pb.append(info)

        # Select all / none
        sel_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        all_btn  = Gtk.Button(label=S["mig_all"])
        none_btn = Gtk.Button(label=S["mig_none"])
