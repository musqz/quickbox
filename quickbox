# ─── locale-aware date helper ─────────────────────────────────────────────────
def _date_tag(with_time=False):
    """Return a date string in locale order: D-M-Y (EU), M-D-Y (US), or Y-M-D (ISO)."""
    try:
        _locale.setlocale(_locale.LC_ALL, '')
        fmt = _locale.nl_langinfo(_locale.D_FMT)  # e.g. '%d/%m/%Y'
        d, m, y = fmt.index('%d'), fmt.find('%m'), max(fmt.find('%Y'), fmt.find('%y'))
        if d < m:        date_fmt = '%d-%m-%Y'   # European
        elif y > m:      date_fmt = '%m-%d-%Y'   # US
        else:            date_fmt = '%Y-%m-%d'   # ISO / Asian
    except Exception:
        date_fmt = '%Y-%m-%d'
    now = datetime.now()
    return now.strftime(date_fmt) + (now.strftime('-%H%M') if with_time else '')

