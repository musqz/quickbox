    def _on_boot_changed(self, dropdown, _pspec, vm, boot_ids):
        idx = dropdown.get_selected()
        if 0 <= idx < len(boot_ids):
            val = boot_ids[idx]
            setconf("boot", val, vm["_conf"])
            vm["boot"] = val

    def _on_display_changed(self, dropdown, _pspec, vm, display_ids):
        idx = dropdown.get_selected()
        if 0 <= idx < len(display_ids):
            val = display_ids[idx]
            setconf("display", val, vm["_conf"])
            vm["display"] = val

    def _on_profile_changed(self, dropdown, _pspec, desc_label, vm, profile_ids):
        idx = dropdown.get_selected()
        if not (0 <= idx < len(profile_ids)):
            return
        pid = profile_ids[idx]
        profile = PROFILES.get(pid, PROFILES["standard"])
        desc_label.set_markup(f'<span size="small" color="gray">{profile["desc"]}</span>')
        setconf("vm_profile", pid, vm["_conf"])
        for key in _PROFILE_KEYS:
            remove_key(key, vm["_conf"])
        for key, val in profile["settings"].items():
            setconf(key, val, vm["_conf"])
        vm["vm_profile"] = pid
        for key in _PROFILE_KEYS:
            vm.pop(key, None)
        vm.update(profile["settings"])
        # Refresh panel so switches (e.g. compat_mode) reflect new profile state
        self._show_panel(vm)

    def _reset_default_profiles(self):
        global PROFILES, _PROFILE_KEYS
        write_default_profiles(overwrite=True)
        PROFILES = load_profiles()
        _PROFILE_KEYS = {key for p in PROFILES.values() for key in p["settings"]}
        notify("quickbox", S["ntf_prof_reset"], "low")

    # ── snapshots ──

    def _snap_create(self, vm):
        tag = self._snap_entry.get_text().strip()
        if not tag:
            return
        if vm["_running"]:
            self._warn(S["vm_running"], S["warn_snap_running_b"])
            return
        disk = vm["_disk"]
        if not Path(disk).exists():
            self._warn(S["warn_no_disk_t"], S["warn_no_disk_b"])
            return
        existing = [s["tag"] for s in get_snapshots(disk)]
        if tag in existing:
            self._warn(S["warn_dup_snap_t"], S["warn_dup_snap_b"].format(tag))
            return
        result = subprocess.run(
            ["qemu-img", "snapshot", "-c", tag, disk],
            capture_output=True, text=True
        )
        if result.returncode == 0:
            self._snap_entry.set_text("")
            notify("quickbox", S["ntf_snap_created"].format(tag), "low")
            self._show_panel(vm)
        else:
            self._warn(S["warn_snap_fail_t"], result.stderr or "qemu-img returned an error.")

    def _snap_apply(self, vm, tag):
        auto_tag = f"pre-apply-{_date_tag(with_time=True)}"

        win = Gtk.Window(title=S["dlg_snap_apply_t"].format(tag))
        win.set_transient_for(self); self._track(win)
        _set_icon(win)
        win.set_modal(True)
        win.set_default_size(460, 200)
        win.set_size_request(360, 160)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_top(20); box.set_margin_bottom(16)
        box.set_margin_start(20); box.set_margin_end(20)

        warn_lbl = Gtk.Label(label=S["dlg_snap_apply_b"])
        warn_lbl.set_halign(Gtk.Align.START)
        warn_lbl.set_wrap(True)
        box.append(warn_lbl)

        # Backup is only needed if the disk changed since the last apply.
        # snap_dirty is set on VM launch and cleared on successful apply.
        disk_unchanged = (vm.get("current_snap") == tag and
                          vm.get("snap_dirty") != "true")

        save_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        if disk_unchanged:
            chk = Gtk.CheckButton(label=S["snap_autosave_skip"])
            chk.set_active(False)
            chk.set_sensitive(False)
            save_row.append(chk)
        else:
            chk = Gtk.CheckButton(label=S["snap_autosave_chk"])
            chk.set_active(True)
            name_entry = Gtk.Entry()
            name_entry.set_text(auto_tag)
            name_entry.set_hexpand(True)
            chk.connect("toggled", lambda c: name_entry.set_sensitive(c.get_active()))
            save_row.append(chk)
            save_row.append(name_entry)
        box.append(save_row)

        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        _sp = Gtk.Box(); _sp.set_hexpand(True)
        btn_row.append(_sp)
        cancel_btn = Gtk.Button(label=S["btn_cancel"])
        cancel_btn.connect("clicked", lambda b: win.close())
        btn_row.append(cancel_btn)
        apply_btn = Gtk.Button(label=S["snap_apply"])
        apply_btn.add_css_class("destructive-action")
        btn_row.append(apply_btn)
        box.append(btn_row)
        win.set_child(box)

        def _do_apply(b):
            save_first = chk.get_active()
            save_name = name_entry.get_text().strip() if (save_first and not disk_unchanged) else auto_tag
            win.close()

            def _run():
                if save_first:
                    r = subprocess.run(
                        ["qemu-img", "snapshot", "-c", save_name, vm["_disk"]],
                        capture_output=True, text=True)
                    if r.returncode != 0:
                        GLib.idle_add(self._warn, S["warn_snap_fail_t"],
                                      f"Auto-save failed: {r.stderr}")
                        return
                    GLib.idle_add(notify, "quickbox",
                                  S["snap_autosave_done"].format(save_name), "low")

                r = subprocess.run(
                    ["qemu-img", "snapshot", "-a", tag, vm["_disk"]],
                    capture_output=True, text=True)
                if r.returncode != 0:
                    GLib.idle_add(self._warn, S["warn_snap_fail_t"],
                                  r.stderr or "qemu-img returned an error.")
                    return
                setconf("current_snap", tag, vm["_conf"])
                vm["current_snap"] = tag
                remove_key("snap_dirty", vm["_conf"])
                vm.pop("snap_dirty", None)
                GLib.idle_add(notify, "quickbox", S["ntf_snap_applied"].format(tag))
                GLib.idle_add(self._show_panel, vm)
                GLib.timeout_add(500, self._refresh)

            threading.Thread(target=_run, daemon=True).start()

        apply_btn.connect("clicked", _do_apply)
        win.present()



    def _snap_delete(self, vm, tag):
        def on_confirm(yes):
            if not yes:
                return
            subprocess.run(["qemu-img", "snapshot", "-d", tag, vm["_disk"]])
            if vm.get("current_snap") == tag:
                remove_key("current_snap", vm["_conf"])
                vm.pop("current_snap", None)
            self._show_panel(vm)
        self._confirm(S["dlg_snap_del_t"].format(tag), S["dlg_snap_del_b"], on_confirm)

