    def _do_migrate(self, dlg):
        # Step 1: pick which VMs to migrate
        vms = get_vms(self.vms_dir)
        if not vms:
            self._warn(S["warn_no_vms_t"], S["warn_no_vms_b"])
            return

        pick = Gtk.Window(title=S["mig_title"])
        pick.set_transient_for(self)
