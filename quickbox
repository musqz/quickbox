# ─── SINGLE INSTANCE LOCK (MUST BE FIRST!) ────────────────────────────────────
import socket
import sys
from pathlib import Path

SOCKET_PATH = Path.home() / ".config/quickbox/quickbox.sock"

def _acquire_lock():
    """Acquire exclusive socket lock - BEFORE anything else runs"""
    SOCKET_PATH.parent.mkdir(parents=True, exist_ok=True)
    try:
        SOCKET_PATH.unlink()
    except FileNotFoundError:
        pass
    
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        sock.bind(str(SOCKET_PATH))
        return sock
    except OSError:
        # Another process has the lock!
        try:
            import subprocess
            subprocess.run(["notify-send", "-u", "normal", "Quickbox", 
                          "ERROR: GUI is already running!"], timeout=5)
        except Exception:
            pass
        print("ERROR: Quickbox GUI is already running!", file=sys.stderr)
        sys.exit(1)

# ACQUIRE LOCK IMMEDIATELY - BEFORE GTK!
_lock_socket = _acquire_lock()

