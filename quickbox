                        dest_conf.chmod(0o755)
                        notify("quickbox", f"VM <b>{vm_name}</b> created!", "low")
                        GLib.idle_add(self._refresh)
                    threading.Thread(target=_copy, daemon=True).start()

            fc.connect("response", _on_file)
            fc.show()

