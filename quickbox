def write_default_profiles(overwrite=False):
    PROFILES_DIR.mkdir(parents=True, exist_ok=True)
    for pid, order, label, desc, settings in _DEFAULT_PROFILES:
        f = PROFILES_DIR / f"{pid}.conf"
        if f.exists() and not overwrite:
            continue
        lines = [f"label={label}", f"desc={desc}", f"order={order}"]
        for k, v in settings.items():
            lines.append(f"{k}={v}")
        f.write_text("\n".join(lines) + "\n")


def load_profiles():
    entries = []
    for f in sorted(PROFILES_DIR.glob("*.conf")):
        data = {}
        try:
            for line in f.read_text().splitlines():
                line = line.strip()
                if "=" in line and not line.startswith("#"):
                    k, _, v = line.partition("=")
                    data[k.strip()] = v.strip()
        except Exception:
            continue
        pid = f.stem
        label = data.get("label", pid)
        desc = data.get("desc", "")
        order = int(data.get("order", "999"))
        settings = {k: v for k, v in data.items() if k not in _PROFILE_META}
        entries.append((order, pid, {"label": label, "desc": desc, "settings": settings}))
    entries.sort(key=lambda x: (x[0], x[1]))
    return {pid: profile for _, pid, profile in entries}


write_default_profiles()
