        for line in Path(path).read_text().splitlines():
            line = line.strip()
            if "=" in line and not line.startswith("#"):
                k, _, v = line.partition("=")
                vm[k.strip()] = v.strip().strip('"')
    except Exception:
        pass
    return vm


def is_running(vmname):
    r = subprocess.run(["pgrep", "-fa", "qemu-system"],
                       capture_output=True, text=True)
    needle = f"name {vmname},process={vmname}"
    return needle in r.stdout


def fmt_size(n):
    for unit in ("B", "K", "M", "G", "T"):
        if n < 1024:
            return f"{n:.0f}{unit}" if unit == "B" else f"{n:.1f}{unit}"
        n /= 1024
    return f"{n:.1f}P"


def _iso_label(vm, vms_dir):
    iso = vm.get("iso", "") or ""
    if not iso:
        return "—"
    if vm.get("_copying"):
        total_bytes = vm.get("_copy_total_bytes", 0)
        total = fmt_size(total_bytes) if total_bytes else ""
        return f"{iso}  ({total})" if total else iso
    try:
        size = fmt_size(Path(vms_dir, iso).stat().st_size)
        return f"{iso}  ({size})"
    except Exception:
        return iso


def dir_size(path):
    try:
        r = subprocess.run(["du", "-sh", path], capture_output=True, text=True)
        return r.stdout.split()[0] if r.stdout.strip() else "?"
    except Exception:
        return "?"

def dir_size_bytes(path):
    try:
        r = subprocess.run(["du", "-sb", path], capture_output=True, text=True)
        return int(r.stdout.split()[0]) if r.stdout.strip() else 0
    except Exception:
        return 0


def get_snapshots(disk_path):
    snaps = []
    try:
        r = subprocess.run(["qemu-img", "snapshot", "-l", disk_path],
                           capture_output=True, text=True)
        for line in r.stdout.splitlines()[2:]:
            parts = line.split()
            if len(parts) >= 2:
                snaps.append({"id": parts[0], "tag": parts[1]})
    except Exception:
        pass
    return snaps


def get_vms(vms_dir):
    vms = []
    for conf_path in sorted(glob.glob(f"{vms_dir}/*.conf")):
        vm = read_vm_conf(conf_path)
        vm["_conf"]    = conf_path
        vm["_name"]    = Path(conf_path).stem
        vm["_pretty"]  = vm.get("pretty", vm["_name"])
        vm["_running"] = is_running(vm["_name"])
        disk = vm.get("disk_img", "")
        vm["_disk"]    = str(Path(vms_dir) / disk) if disk else ""
        vm["_has_disk"] = Path(vm["_disk"]).exists() if vm["_disk"] else False
        flag_path = Path(vms_dir) / f".{vm['_name']}.copying"
        vm["_copying"] = flag_path.exists()
        vm["_copy_total_bytes"] = 0
        vm["_copy_done_bytes"] = 0
        if vm["_copying"]:
            try:
                vm["_copy_total_bytes"] = int(flag_path.read_text().strip())
            except Exception:
                pass
            vm["_copy_done_bytes"] = dir_size_bytes(str(Path(vms_dir) / vm["_name"]))
        vm["_size"]    = dir_size(str(Path(vms_dir) / vm["_name"]))
        vms.append(vm)
    vms.sort(key=lambda v: (not v["_running"], v["_name"].lower()))
    return vms


