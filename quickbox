    def _ensure_ssh_config(self, vm):
        """Set SSH user and port in VM config."""
        guest_os = vm.get("guest_os", "linux")
        ssh_user = get_ssh_user(guest_os)
        ssh_port = vm.get("ssh_port", "")
        
        if not ssh_port:
            ssh_port = get_next_ssh_port(self.vms_dir, vm["_name"])
            setconf("ssh_port", ssh_port, vm["_conf"])
            vm["ssh_port"] = ssh_port
        
        if not vm.get("ssh_user"):
            setconf("ssh_user", ssh_user, vm["_conf"])
            vm["ssh_user"] = ssh_user
        else:
            ssh_user = vm["ssh_user"]
        
        # Add netdev to compat mode if needed
        if vm.get("compat_mode") == "true" and not vm.get("netdev"):
            netdev_line = f"user,hostname={vm['_name']},hostfwd=tcp::{ssh_port}-:22,id=nic"
            setconf("netdev", netdev_line, vm["_conf"])
            vm["netdev"] = netdev_line


