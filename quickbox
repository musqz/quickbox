            filt.add_pattern("*.iso"); filt.add_pattern("*.ISO")
            filt.add_pattern("*.img"); filt.add_pattern("*.IMG")
            fc.add_filter(filt)

            def _on_file(chooser, response):
                if response != Gtk.ResponseType.ACCEPT:
                    return
                gfile = chooser.get_file()
                if not gfile:
                    return
                src_path = Path(gfile.get_path())
                dest_dir.mkdir(parents=True, exist_ok=True)
                ssh_port = get_next_ssh_port(self.vms_dir, dest_name)

                if src_path.suffix.lower() == ".img":
                    conf_text = (f"#!/usr/bin/quickemu --vm\n"
                                 f"guest_os=\"linux\"\n"
                                 f"disk_img=\"{dest_name}/disk.qcow2\"\n"
                                 f"iso=\"\"\n"
                                 f"pretty=\"{vm_name}\"\n"
                                 f"ssh_port=\"{ssh_port}\"\n"
                                 f"boot=legacy\n"
                                 f"compat_mode=true\n"
                                 f"disk_if=ide\n"
