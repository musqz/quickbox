            ("gpt_esp_ext4", S["fmt_layout_gpt"], S["tt_fmt_gpt"]),
            ("msdos_ext4",   S["fmt_layout_msd"], S["tt_fmt_msd"]),
            ("msdos_fat32",  S["fmt_layout_fat"], S["tt_fmt_fat"]),
            ("blank",        S["fmt_layout_raw"], S["tt_fmt_raw"]),
        ]

        radios = []
        first = None
        for lid, lname, ldesc in layouts:
            rb = Gtk.CheckButton(label=lname)
            rb._layout_id = lid
            if first is None:
                first = rb
            else:
                rb.set_group(first)
            rb.set_tooltip_text(ldesc)
            radios.append(rb)
