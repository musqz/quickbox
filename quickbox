    def _test_ssh(self, vm, btn):
        port = int(vm.get("ssh_port", "2222"))
        btn.set_sensitive(False)
        btn.set_label("Testing…")

        def do_test():
            try:
                with socket.create_connection(("localhost", port), timeout=3):
                    pass
                reachable = True
            except Exception:
                reachable = False
            GLib.idle_add(lambda: _show_result(reachable))

        def _show_result(ok):
            if ok:
                btn.set_label("Reachable")
                btn.get_style_context().add_class("launch-btn")
            else:
                btn.set_label("Not reachable")
            btn.set_sensitive(True)

        threading.Thread(target=do_test, daemon=True).start()

