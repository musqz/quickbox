def _load_translation(lang: str) -> dict:
    search_dirs = [
        Path(__file__).parent / "translations",
        Path.home() / ".local/share/quickbox/translations",
        Path("/usr/share/quickbox/translations"),
    ]
    for lang_code in (lang, "en"):
        for d in search_dirs:
            path = d / f"{lang_code}.json"
            if path.exists():
                try:
                    data = _json.loads(path.read_text(encoding="utf-8"))
                    return {**_EN_STRINGS, **data}
                except Exception:
                    pass
    return _EN_STRINGS

