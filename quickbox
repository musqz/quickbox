        box.append(btn_box)


        # State — local to this dialog, not instance vars
        _dl = {"process": None, "cancelled": False, "watching": False}

        def _run_download():
            import subprocess as sp, time as _time, math as _math
            cmd = cmd_entry.get_text().strip().split()
            GLib.idle_add(progress.set_text, S["dl2_starting"])
            GLib.idle_add(dl_btn.set_sensitive, False)
            GLib.idle_add(ver_combo.set_sensitive, False)

            t0 = _time.monotonic()

            def _find_file():
                try:
                    cutoff = t0 - 2.0
                    files = []
                    for f in Path(self.vms_dir).rglob("*"):
                        if f.is_file() and f.suffix.lower() in (
                                ".iso", ".img", ".qcow2", ".gz", ".xz", ".zip",
                                ".part", ".tmp", ".download"):
                            st = f.stat()
                            if st.st_mtime >= cutoff:
                                files.append((st.st_mtime, f))
                    return sorted(files)[-1][1] if files else None
                except Exception:
                    return None

            def _set_indeterminate():
                progress.set_fraction(0)
                progress.pulse()

            def _set_determinate(frac):
                progress.set_fraction(frac)

            def _watch_progress():
                elapsed, last_size, last_mb, target, stall = 0, 0, 0.0, None, 0
                while _dl["watching"] and not _dl["cancelled"]:
                    _time.sleep(1)
                    elapsed += 1
                    dot = "." * (elapsed % 4)
                    if target is None or not target.exists():
                        target = _find_file()
                    if target and target.exists():
                        try:
                            size = target.stat().st_size
                            mb = size / (1024 * 1024)
                            if size > last_size:
                                frac = _math.log1p(mb) / (_math.log1p(mb) + 8)
                                speed = (size - last_size) / (1024 * 1024)
                                last_mb, last_size, stall = mb, size, 0
                                GLib.idle_add(_set_determinate, min(frac, 0.95))
                                GLib.idle_add(progress.set_text,
                                    S["dl2_progress"].format(f"{mb:.0f}", f"{speed:.1f}"))
                            else:
                                stall += 1
                                if stall >= 5:
                                    GLib.idle_add(_set_indeterminate)
                                    GLib.idle_add(progress.set_text,
                                        f"Server is slow — {last_mb:.0f} MB received, still connected{dot}  ({stall}s)")
                                else:
                                    GLib.idle_add(progress.set_text,
                                        S["dl2_progress"].format(f"{last_mb:.0f}", "–"))
                        except Exception:
                            pass
                    else:
                        GLib.idle_add(_set_indeterminate)
                        if elapsed <= 3:
                            GLib.idle_add(progress.set_text, S["dl2_starting"])
                        else:
                            hint = "  —  slow servers may take a minute" if elapsed > 15 else ""
                            GLib.idle_add(progress.set_text,
                                f"Contacting server{dot}  ({elapsed}s){hint}")

            _dl["watching"] = True
            watcher = threading.Thread(target=_watch_progress, daemon=True)
            watcher.start()

            _dl_stderr = ""
            try:
                import shlex as _shlex
                qg_bin = _resolve_quickget() or "quickget"
                cmd[0] = qg_bin
                _shell = os.environ.get("SHELL", "/bin/sh")
                _cmd_str = " ".join(_shlex.quote(c) for c in cmd)
                Path(self.vms_dir).mkdir(parents=True, exist_ok=True)
                _dl["process"] = sp.Popen(
                    [_shell, "-c", _cmd_str],
                    stdin=sp.DEVNULL, stdout=sp.PIPE, stderr=sp.STDOUT,
                    cwd=self.vms_dir
                )
                _out_bytes, _ = _dl["process"].communicate()
                _dl_stderr = _out_bytes.decode(errors="replace").strip() if _out_bytes else ""
                rc = _dl["process"].returncode
            except Exception as e:
                _dl_stderr = str(e)
                rc = 1

            _dl["watching"] = False
            _time.sleep(1.2)

            def _fmt_duration(secs):
                secs = int(secs)
                if secs < 60:
                    return f"{secs}s"
                elif secs < 3600:
                    m, s = divmod(secs, 60)
                    return f"{m}m {s}s"
                else:
                    h, rem = divmod(secs, 3600)
                    return f"{h}h {rem // 60}m"

            if _dl["cancelled"]:
                GLib.idle_add(progress.set_text, S["dl2_cancelled"])
                GLib.idle_add(_set_determinate, 0)
            elif rc == 0:
                elapsed = _time.monotonic() - t0
                GLib.idle_add(progress.set_text, S["dl2_verifying"])
                _time.sleep(1.0)
                GLib.idle_add(_set_determinate, 1.0)
                GLib.idle_add(progress.set_text, S["dl2_done"])
                GLib.idle_add(note.set_markup,
                    f'<span size="small" color="gray">Downloaded in {_fmt_duration(elapsed)}</span>')
                GLib.idle_add(dl_btn.set_label, S["dl2_done_close"])
                GLib.idle_add(dl_btn.set_sensitive, True)
                def _refresh_and_select():
                    self._refresh()
                    try:
                        confs = sorted(Path(self.vms_dir).glob("*.conf"),
                                       key=lambda p: p.stat().st_mtime, reverse=True)
                        if confs:
                            GLib.timeout_add(400, self._select_vm_by_name, confs[0].stem)
                    except Exception:
                        pass
                GLib.idle_add(_refresh_and_select)
            else:
                if _dl_stderr:
                    err_short = _dl_stderr.splitlines()[-1][:80]
                else:
                    err_short = f"failed (exit {rc}) — no output from quickget"
                GLib.idle_add(progress.set_text, err_short)
                GLib.idle_add(_set_determinate, 0)
                GLib.idle_add(dl_btn.set_label, S["btn_close"])
                GLib.idle_add(dl_btn.set_sensitive, True)

        def _on_download(btn):
            if btn.get_label() in (S["dl2_done_close"], S["btn_close"]):
                dlg.close()
                return
            threading.Thread(target=_run_download, daemon=True).start()

        def _on_cancel(btn):
            if _dl["process"] and _dl["process"].poll() is None:
                _dl["cancelled"] = True
                _dl["process"].terminate()
            dlg.close()

        dl_btn.connect("clicked", _on_download)
        cancel_btn.connect("clicked", _on_cancel)
        dlg.connect("close-request", lambda w: _on_cancel(cancel_btn) or False)

        box.set_vexpand(True)
        dlg.set_child(box)
        dlg.present()


