                        vm_dir = str(Path(self.vms_dir) / vm["_name"])
                        if Path(vm_dir).exists():
                            rsync_cmd.append(vm_dir)
                        rsync_cmd.append(vm["_conf"])
                    rsync_cmd.append(f"{newdir}/")

                    def _migration_done(ok):
                        if not ok:
                            self._warn("Migration failed", "rsync returned an error.")
                            return
                        def on_danger(yes):
                            if yes:
                                for vm in selected:
                                    vm_dir = Path(self.vms_dir) / vm["_name"]
                                    if vm_dir.exists():
                                        shutil.rmtree(str(vm_dir))
                                    if Path(vm["_conf"]).exists():
                                        Path(vm["_conf"]).unlink()
                            self._refresh()
                            self._refresh_loc_list(dlg)
                        self._confirm_danger(
                            "Remove original files?",
                            f"Migration succeeded.\n\n"
                            f"Do you want to PERMANENTLY DELETE the {len(selected)} "
                            f"migrated VM(s) from the original location?\n\n"
                            f"{self.vms_dir}\n\n"
                            f"This cannot be undone. The copies in the new location will remain.",
                            on_danger
                        )

                    self._run_with_progress(
                        f"Migrating {len(selected)} VM(s)",
                        rsync_cmd,
                        on_done=_migration_done
                    )
                self._confirm(
                    "Start migration?",
                    f"Copy {len(selected)} VM(s) to:\n{newdir}\n\n  • {names}\n\n"
                    f"Originals will remain unless you confirm removal afterwards.",
                    on_confirm
                )

            self._pick_dir("Select destination for migration", str(Path.home()), _on_folder)

        next_pick.connect("clicked", _on_next_pick)
        pick.present()

    def _do_add_loc(self, dlg):
        def _on_dir(loc):
            if not loc:
                return
            conf = read_conf()
            for i in range(1, 6):
                if not conf.get(f"vms_dir_{i}"):
                    setconf(f"vms_dir_{i}", loc)
                    self._refresh_loc_list(dlg)
                    return
            self._warn("List full", "Maximum 5 saved locations. Remove one first.")
        self._pick_dir("Select directory to add to switch list", str(Path.home()), _on_dir)

    # ── dialogs helpers ──

    def _run_with_progress(self, title, cmd_list, cwd=None, on_done=None):
        dlg = Gtk.Window(title=title)
        dlg.set_transient_for(self)
        dlg.set_modal(True)
        dlg.set_deletable(False)
        dlg.set_default_size(460, 160)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        box.set_margin_top(16); box.set_margin_bottom(16)
        box.set_margin_start(16); box.set_margin_end(16)

        status_lbl = Gtk.Label(label="Please wait…")
        status_lbl.set_halign(Gtk.Align.START)
        box.append(status_lbl)

        progress = Gtk.ProgressBar()
        progress.set_show_text(False)
        box.append(progress)

        note = Gtk.Label()
        note.set_markup('<span size="small" color="gray">This may take a while depending on size.</span>')
        note.set_halign(Gtk.Align.START)
        box.append(note)

        dlg.set_child(box)
        dlg.present()

        def _pulse():
            progress.pulse()
            return self._proc_running

        self._proc_running = True
        GLib.timeout_add(150, _pulse)

        def _run():
            try:
                proc = subprocess.run(
                    cmd_list, cwd=cwd,
                    capture_output=True, text=True
                )
                rc = proc.returncode
            except Exception:
                rc = 1

            self._proc_running = False

            if rc == 0:
                GLib.idle_add(progress.set_fraction, 1.0)
                GLib.idle_add(status_lbl.set_text, "Done!")
                GLib.idle_add(note.set_markup,
                    '<span size="small" color="gray">Completed successfully.</span>')
            else:
                GLib.idle_add(status_lbl.set_text, "Failed.")
                GLib.idle_add(note.set_markup,
                    '<span size="small" color="red">Something went wrong.</span>')

            def _finish():
                dlg.close()
                if on_done:
                    on_done(rc == 0)
            GLib.timeout_add(1200, _finish)

        threading.Thread(target=_run, daemon=True).start()

    def _pick_dir(self, title, start, callback):
        fc = Gtk.FileChooserNative(title=title,
                                   transient_for=self,
                                   action=Gtk.FileChooserAction.SELECT_FOLDER)
        initial = Gio.File.new_for_path(start)
        fc.set_current_folder(initial)
        def _on_response(chooser, response):
            if response == Gtk.ResponseType.ACCEPT:
                gfile = chooser.get_file()
                callback(gfile.get_path() if gfile else None)
            else:
                callback(None)
        fc.connect("response", _on_response)
        fc.show()

    def _confirm(self, title, body, callback):
        dlg = Gtk.AlertDialog()
        dlg.set_message(title)
        dlg.set_detail(body)
        dlg.set_buttons(["Cancel", "Yes"])
        dlg.set_default_button(0)
        dlg.set_cancel_button(0)
        def _on_response(d, result):
            try:
                idx = d.choose_finish(result)
                callback(idx == 1)
            except Exception:
                callback(False)
        dlg.choose(self, None, _on_response)

    def _confirm_danger(self, title, body, callback):
        dlg = Gtk.AlertDialog()
        dlg.set_message(title)
        dlg.set_detail(body)
        dlg.set_buttons(["No, keep files", "Yes, delete originals"])
        dlg.set_default_button(0)
        dlg.set_cancel_button(0)
        def _on_response(d, result):
            try:
                idx = d.choose_finish(result)
                callback(idx == 1)
            except Exception:
                callback(False)
        dlg.choose(self, None, _on_response)

    def _warn(self, title, body):
        dlg = Gtk.AlertDialog()
        dlg.set_message(title)
        dlg.set_detail(body)
        dlg.set_buttons(["OK"])
        dlg.show(self)


