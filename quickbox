                        notify("quickbox", f"VM <b>{vm_name}</b> created!", "low")
                        GLib.idle_add(self._refresh)
                    threading.Thread(target=_convert, daemon=True).start()
                else:
                    notify("quickbox", f"Copying {src_path.name}…", "low")
                    def _copy():
                        shutil.copy2(str(src_path), str(dest_dir / src_path.name))
                        conf_text = (f"#!/usr/bin/quickemu --vm\n"
                                     f"guest_os=\"linux\"\n"
