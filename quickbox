# ─── VM launch profiles ───────────────────────────────────────────────────────
# Profiles live in ~/.config/quickbox/profiles/*.conf (key=value format).
# Special keys: label, desc, order — everything else is written to the VM conf.
# Users can add/edit files freely; defaults are restored with Reset in Advanced.

PROFILES_DIR = Path.home() / ".config/quickbox/profiles"
_PROFILE_META = {"label", "desc", "order"}

_DEFAULT_PROFILES = [
    ("standard",    1, "Standard",        "Default setup — UEFI boot, disk created on first launch.", {}),
    ("live_iso",    2, "Live ISO",         "Boot fresh from ISO every time. No disk created or needed.", {"live_mode": "true"}),
