    def _launch_vm(self, vm):
        """
        Launch VM with proper boot/reboot handling.
        
        FIXED BOOT CHAIN (v2):
        - OVMF_VARS.fd created once, NEVER reset (persists EFI bootloader registration)
        - PATH A: ISO + Disk (install phase) -> uses persistent OVMF_VARS + -boot order=d
        - PATH B: Disk only (post-install) -> uses saved OVMF_VARS with bootloader entry
        - PATH C: Special modes (legacy, raw IMG) -> separate handling
        """
        vmname    = vm["_name"]
        vmdir     = str(Path(self.vms_dir) / vmname)
        conf_path = vm["_conf"]
        compat    = vm.get("compat_mode") == "true"
        boot      = vm.get("boot", "uefi")
        confirmed = vm.get("confirmed") == "true"
        disk_if   = vm.get("disk_if", "")
        net_dev   = vm.get("net_device", "e1000")
        disk_img  = vm.get("disk_img", "")
        iso       = vm.get("iso", "")
        disk_path = str(Path(self.vms_dir) / disk_img) if disk_img else ""
        iso_path  = str(Path(self.vms_dir) / iso) if iso else ""
        ram       = vm.get("ram", "4G")
        cpu_cores = vm.get("cpu_cores", "2")
        live_mode = vm.get("live_mode") == "true"
        headless  = vm.get("headless") == "true"
        
        # Create vmdir if needed
        Path(vmdir).mkdir(parents=True, exist_ok=True)

        # OVMF setup — persistent, never reset
        ovmf_vars = str(Path(vmdir) / "OVMF_VARS.fd")
        if boot == "uefi":
            # Create OVMF_VARS ONCE. Then leave it alone forever.
            # This allows EFI bootloader registration to persist across installs.
            if not Path(ovmf_vars).exists() and OVMF_VARS_TEMPLATE:
                shutil.copy(str(OVMF_VARS_TEMPLATE), ovmf_vars)

        # Ensure disk exists (skip in live_mode — boots from ISO only)
        if disk_path and not Path(disk_path).exists() and not live_mode:
            disk_size = vm.get("disk_size", "32G")
            subprocess.run(["qemu-img", "create", "-f", "qcow2", disk_path, disk_size])

        # Ensure SSH config before launch
        self._ensure_ssh_config(vm)

        accel   = "kvm" if KVM_AVAILABLE else "tcg"

        notify("quickbox", f"Launching {vmname}", "low")

        # Base QEMU args (all modes)
        base_args = [
            "qemu-system-x86_64",
            "-name", f"{vmname},process={vmname}",
            "-machine", f"q35,accel={accel}",
            "-cpu", "host" if KVM_AVAILABLE else "max",
            "-m", ram,
            "-smp", cpu_cores,
            "-vga", "std",
            "-display", "none" if headless else "gtk,zoom-to-fit=on",
            "-no-reboot",
        ]

        log = f"/tmp/qemu-{vmname}.log"
        ssh_port = vm.get("ssh_port", "2222")

        if compat:
            # PATH C: Special modes (EasyOS raw IMG, legacy boot, custom disk_if)
            # ──────────────────────────────────────────────────────────────────
            if disk_if:
                # EasyOS or other custom formats with disk_if (ide, ahci, etc)
                cmd = base_args + [
                    "-drive", f"format=qcow2,file={disk_path},if={disk_if}",
                    "-device", f"{net_dev},netdev=nic",
                    "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                ]
            # ──────────────────────────────────────────────────────────────────
            # PATH A+C: Raw IMG file (legacy or UEFI)
            # ──────────────────────────────────────────────────────────────────
            elif iso_path and iso_path.endswith((".img", ".IMG")):
                # Raw disk image — use as-is, no CDROM
                if boot == "uefi" and OVMF_CODE:
                    # UEFI + raw IMG
                    cmd = base_args + [
                        "-drive", f"if=pflash,format=raw,unit=0,file={OVMF_CODE},readonly=on",
                        "-drive", f"if=pflash,format=raw,unit=1,file={ovmf_vars}",
                        "-drive", f"format=raw,file={iso_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]
                else:
                    # Legacy + raw IMG
                    cmd = base_args + [
                        "-boot", "order=c",
                        "-drive", f"format=raw,file={iso_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]
            # ──────────────────────────────────────────────────────────────────
            # PATH A: ISO + Disk (install phase)
            # ──────────────────────────────────────────────────────────────────
            elif iso_path and Path(iso_path).exists():
                # Have both ISO and disk — installation phase
                if boot == "uefi" and OVMF_CODE:
                    # UEFI ISO install
                    # -boot order=d forces CDROM first during install
                    # Bootloader writes EFI entry to ovmf_vars.fd
                    # Post-install reboot: firmware finds entry, boots disk
                    cmd = base_args + [
                        "-boot", "order=d",
                        "-drive", f"if=pflash,format=raw,unit=0,file={OVMF_CODE},readonly=on",
                        "-drive", f"if=pflash,format=raw,unit=1,file={ovmf_vars}",
                        "-drive", f"media=cdrom,file={iso_path}",
                        "-drive", f"format=qcow2,file={disk_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]
                else:
                    # Legacy ISO install
                    cmd = base_args + [
                        "-boot", "order=d",
                        "-drive", f"media=cdrom,file={iso_path}",
                        "-drive", f"format=qcow2,file={disk_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]
            # ──────────────────────────────────────────────────────────────────
            # PATH B: Disk only (post-install)
            # ──────────────────────────────────────────────────────────────────
            else:
                # ISO removed or missing — post-install phase, boot from disk
                if boot == "uefi" and OVMF_CODE:
                    # UEFI disk boot
                    # ovmf_vars.fd has bootloader entry from install
                    # No -boot order override; firmware uses saved entry
                    cmd = base_args + [
                        "-drive", f"if=pflash,format=raw,unit=0,file={OVMF_CODE},readonly=on",
                        "-drive", f"if=pflash,format=raw,unit=1,file={ovmf_vars}",
                        "-drive", f"format=qcow2,file={disk_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]
                else:
                    # Legacy disk boot
                    cmd = base_args + [
                        "-boot", "order=c",
                        "-drive", f"format=qcow2,file={disk_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]

        else:
            # Normal quickemu path (non-compat)
            cmd = ["quickemu", "--vm", conf_path]

        with open(log, "w") as logfile:
            subprocess.Popen(cmd, stdout=logfile, stderr=logfile)

        GLib.timeout_add(3000, self._refresh)

    def _select_vm_by_name(self, name):
        row = self.listbox.get_first_child()
        while row is not None:
            if hasattr(row, "vm") and row.vm["_name"] == name:
                self.listbox.select_row(row)
                self.current_vm = row.vm
                self._show_panel(row.vm)
                return False
            row = row.get_next_sibling()
        return False

    def _stop_vm(self, vm):
        subprocess.Popen(["pkill", "-f", f"name {vm['_name']},process={vm['_name']}"])
        GLib.timeout_add(1500, self._refresh)

    # ── boot mode ──

    def _on_boot_changed(self, combo, vm):
        val = combo.get_active_id()
        if val:
            setconf("boot", val, vm["_conf"])
            vm["boot"] = val

    def _on_profile_changed(self, combo, desc_label, vm):
        pid = combo.get_active_id()
        if pid is None:
            return
        profile = PROFILES.get(pid, PROFILES["standard"])
        desc_label.set_markup(f'<span size="small" color="gray">{profile["desc"]}</span>')
        setconf("vm_profile", pid, vm["_conf"])
        for key in _PROFILE_KEYS:
            remove_key(key, vm["_conf"])
        for key, val in profile["settings"].items():
            setconf(key, val, vm["_conf"])
        vm["vm_profile"] = pid
        for key in _PROFILE_KEYS:
            vm.pop(key, None)
        vm.update(profile["settings"])
        # Refresh panel so switches (e.g. compat_mode) reflect new profile state
        self._show_panel(vm)

    def _reset_default_profiles(self):
        global PROFILES, _PROFILE_KEYS
        write_default_profiles(overwrite=True)
        PROFILES = load_profiles()
        _PROFILE_KEYS = {key for p in PROFILES.values() for key in p["settings"]}
        notify("quickbox", "Default profiles restored.", "low")

    # ── snapshots ──

    def _snap_create(self, vm):
        tag = self._snap_entry.get_text().strip()
        if not tag:
            return
        if vm["_running"]:
            self._warn("VM is running", "Stop the VM before creating a snapshot.")
            return
        disk = vm["_disk"]
        if not Path(disk).exists():
            self._warn("No disk", "Disk image not found.")
            return
        existing = [s["tag"] for s in get_snapshots(disk)]
        if tag in existing:
            self._warn("Duplicate tag", f"Snapshot '{tag}' already exists.")
            return
        result = subprocess.run(
            ["qemu-img", "snapshot", "-c", tag, disk],
            capture_output=True, text=True
        )
        if result.returncode == 0:
            self._snap_entry.set_text("")
            notify("quickbox", f"Snapshot '{tag}' created.", "low")
            self._show_panel(vm)
        else:
            self._warn("Snapshot failed", result.stderr or "qemu-img returned an error.")

    def _snap_apply(self, vm, tag):
        def on_confirm(yes):
            if not yes:
                return
            subprocess.run(["qemu-img", "snapshot", "-a", tag, vm["_disk"]])
            notify("quickbox", f"Snapshot '{tag}' applied. Launch VM from menu.")
        self._confirm(f"Apply snapshot '{tag}'?",
                      "This will overwrite the current disk state.",
                      on_confirm)

    def _snap_delete(self, vm, tag):
        def on_confirm(yes):
            if not yes:
                return
            subprocess.run(["qemu-img", "snapshot", "-d", tag, vm["_disk"]])
            self._show_panel(vm)
        self._confirm(f"Delete snapshot '{tag}'?", "This cannot be undone.", on_confirm)

    # ── clone ──

    def _clone_vm(self, vm):
        import datetime
        date_str  = datetime.datetime.now().strftime("%Y%m%d")
        suggested = f"{vm['_name']}-{date_str}"

        win = Gtk.Window(title="Clone VM")
        win.set_transient_for(self)
        win.set_modal(True)
        win.set_default_size(380, 180)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_margin_top(16); box.set_margin_bottom(16)
        box.set_margin_start(16); box.set_margin_end(16)
        box.append(Gtk.Label(label=f"Clone '{vm['_pretty']}' as:"))
        entry = Gtk.Entry()
        entry.set_text(suggested)
        entry.set_tooltip_text("Name for the cloned VM — date suffix helps track when it was made")
        box.append(entry)
        hint = Gtk.Label()
        hint.set_markup('<span size="small" color="gray">The clone will appear in the VM list as a separate VM.</span>')
        hint.set_halign(Gtk.Align.START)
        box.append(hint)
        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_box.set_margin_top(8)
        _sp = Gtk.Box(); _sp.set_hexpand(True)
        btn_box.append(_sp)
        cancel_btn = Gtk.Button(label="Cancel")
        cancel_btn.connect("clicked", lambda b: win.close())
        btn_box.append(cancel_btn)
        clone_btn = Gtk.Button(label="Clone")
        clone_btn.get_style_context().add_class("suggested-action")
        btn_box.append(clone_btn)
        box.append(btn_box)
        win.set_child(box)

        def _do_clone(b):
            name = entry.get_text().strip()
            win.close()
            if not name:
                return
            dest_name = name.replace(" ", "-").lower()
            dest_dir  = Path(self.vms_dir) / dest_name
            dest_conf = Path(self.vms_dir) / f"{dest_name}.conf"
            src_dir   = Path(self.vms_dir) / vm["_name"]
            src_conf  = Path(vm["_conf"])

            if dest_dir.exists() or dest_conf.exists():
                self._warn("Already exists", f"VM '{dest_name}' already exists.")
                return

            try:
                src_vm = read_vm_conf(str(src_conf))
                skip_keys = {"vm_ram", "vm_cpu", "ssh_port"}
                out = ["#!/usr/bin/quickemu --vm"]
                for k, v in src_vm.items():
                    if k in skip_keys:
                        continue
                    if k == "pretty":
                        out.append(f'pretty="{name}"')
                    elif k == "disk_img" and v and vm["_name"] in v:
                        out.append(f'{k}="{v.replace(vm["_name"], dest_name)}"')
                    elif v:
                        out.append(f'{k}="{v}"')
                    else:
                        out.append(f'{k}=')
                if "pretty" not in src_vm:
                    out.append(f'pretty="{name}"')
                dest_conf.write_text("\n".join(out) + "\n")
                dest_conf.chmod(0o755)
            except Exception as e:
                self._warn("Clone failed", f"Could not write conf: {e}")
                return

            self._refresh()
            self._select_vm_by_name(dest_name)
            flag = Path(self.vms_dir) / f".{dest_name}.copying"
            flag.touch()

            def _copy_dir():
                try:
                    shutil.copytree(str(src_dir), str(dest_dir))
                    flag.unlink(missing_ok=True)
                    notify("quickbox", f"Clone complete: '{name}' — ready to use", "low")
                    GLib.idle_add(self._refresh)
                    GLib.timeout_add(200, lambda: self._select_vm_by_name(dest_name) or False)
                except Exception as e:
                    flag.unlink(missing_ok=True)
                    GLib.idle_add(self._warn, "Clone failed", f"Directory copy failed: {str(e)}")
                    GLib.idle_add(dest_conf.unlink)

            threading.Thread(target=_copy_dir, daemon=True).start()

        clone_btn.connect("clicked", _do_clone)
        win.present()

