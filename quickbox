        btn_box.append(_sp)
        cancel_btn = Gtk.Button(label=S["btn_cancel"])
        cancel_btn.connect("clicked", lambda b: win.close())
        btn_box.append(cancel_btn)
        clone_btn = Gtk.Button(label=S["btn_clone"])
        clone_btn.add_css_class("suggested-action")
        btn_box.append(clone_btn)
        box.append(btn_box)
        win.set_child(box)

        def _do_clone(b):
            name = entry.get_text().strip()
            win.close()
            if not name:
                return
            dest_name = name.replace(" ", "-").lower()
            dest_dir  = Path(self.vms_dir) / dest_name
            dest_conf = Path(self.vms_dir) / f"{dest_name}.conf"
            src_dir   = Path(self.vms_dir) / vm["_name"]
            src_conf  = Path(vm["_conf"])

            if dest_dir.exists() or dest_conf.exists():
                self._warn(S["warn_exists_t"], S["warn_exists_b"].format(dest_name))
                return

            try:
                src_vm = read_vm_conf(str(src_conf))
                skip_keys = {"vm_ram", "vm_cpu", "ssh_port"}
                out = ["#!/usr/bin/quickemu --vm"]
                for k, v in src_vm.items():
                    if k in skip_keys:
                        continue
                    if k == "pretty":
                        out.append(f'pretty="{name}"')
                    elif k == "disk_img" and v and vm["_name"] in v:
                        out.append(f'{k}="{v.replace(vm["_name"], dest_name)}"')
                    elif v:
                        out.append(f'{k}="{v}"')
                    else:
                        out.append(f'{k}=')
                if "pretty" not in src_vm:
                    out.append(f'pretty="{name}"')
                new_port = get_next_ssh_port(self.vms_dir, dest_name)
                out.append(f'ssh_port="{new_port}"')
                dest_conf.write_text("\n".join(out) + "\n")
                dest_conf.chmod(0o755)
            except Exception as e:
                self._warn(S["warn_clone_t"], S["warn_clone_conf"].format(e))
                return

            self._refresh()
            self._select_vm_by_name(dest_name)
            flag = Path(self.vms_dir) / f".{dest_name}.copying"
            flag.touch()

            def _copy_dir():
                try:
                    shutil.copytree(str(src_dir), str(dest_dir))
                    flag.unlink(missing_ok=True)
                    notify("quickbox", S["ntf_clone_done"].format(name), "low")
                    GLib.idle_add(self._refresh)
                    GLib.timeout_add(200, lambda: self._select_vm_by_name(dest_name) or False)
                except Exception as e:
                    flag.unlink(missing_ok=True)
                    GLib.idle_add(self._warn, S["warn_clone_t"], S["warn_clone_dir"].format(str(e)))
                    GLib.idle_add(dest_conf.unlink)

            threading.Thread(target=_copy_dir, daemon=True).start()

        clone_btn.connect("clicked", _do_clone)
        win.present()

