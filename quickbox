class QuickboxWindow(Gtk.ApplicationWindow):
    def __init__(self, **kwargs):
        super().__init__(title="Quickbox", **kwargs)
        _register_icons()
        self.set_default_size(900, 620)
        self.set_size_request(720, 480)
        self.set_resizable(True)
        self.set_icon_name(APP_ICON)
        self.conf      = read_conf()
        self.vms_dir   = self.conf.get("vms_dir", str(Path.home() / "emu"))
        self.current_vm = None
        self._search_text = ""
        self._vms_dir_mtime = 0
        self._conf_mtimes = {}
        self._any_importing = False
        # Clean up stale copy flags left by a previous crashed/killed session
        for _f in Path(self.vms_dir).glob(".*.copying"):
            _f.unlink(missing_ok=True)
        self._timeout_handlers = []
        self._indicator = None
        self._transients = []
        self._build_css()
        self._build_ui()
        self._refresh()
        self._init_systray()
        self._init_ipc()
        self.connect("close-request", self._on_close_request)
        # poll VM running state and vms_dir changes every 4 seconds
        self._timeout_handlers.append(GLib.timeout_add(4000, self._poll_running_state))
        self._timeout_handlers.append(GLib.timeout_add(4000, self._poll_vms_dir))
        # poll copying progress every 2 seconds
        self._timeout_handlers.append(GLib.timeout_add(2000, self._poll_copying))

    # ── IPC: raise window when a second instance tries to start ──

    def _init_ipc(self):
        GLib.io_add_watch(_lock_socket.fileno(), GLib.IOCondition.IN, self._on_ipc)

    def _on_ipc(self, fd, condition):
        try:
            conn, _ = _lock_socket.accept()
            msg = conn.recv(64).decode().strip()
            conn.close()
            if "activate" in msg:
                self.set_visible(True)
                self.present()
        except Exception:
            pass
        return True

    # ── system tray ──

    def _init_systray(self):
        if self.conf.get("systray") != "true":
            return
        try:
            _local_svg = Path(__file__).parent / "icons/hicolor/scalable/apps/quickbox.svg"
            _svg_arg = str(_local_svg) if _local_svg.exists() else ""
            self._tray_proc = subprocess.Popen(
                ["python3", "-c", _TRAY_HELPER, "quickbox", _svg_arg],
                stdin=subprocess.PIPE, stdout=subprocess.PIPE, text=True)
            GLib.io_add_watch(
                self._tray_proc.stdout.fileno(),
                GLib.IO_IN, self._on_tray_output)
            self._indicator = self._tray_proc
            GLib.timeout_add(200, self._push_tray_vms)
        except Exception:
            self._indicator = None

    def _on_tray_output(self, fd, condition):
        try:
            line = os.read(fd, 256).decode().strip()
            if line.startswith("stop:"):
                name = line[5:]
                GLib.idle_add(self._stop_vm_by_name, name)
            elif line == "show":
                GLib.idle_add(self._tray_show)
            elif "activate" in line:
                GLib.idle_add(self._tray_toggle)
            elif "quit" in line:
                GLib.idle_add(self._tray_quit)
            return True
        except Exception:
            return False

    def _stop_vm_by_name(self, name):
        def on_confirm(yes):
            if not yes:
                return
            needle = f"name {name},process={name}"
            r = subprocess.run(["pgrep", "-fa", "qemu-system"], capture_output=True, text=True)
            for line in r.stdout.splitlines():
                if needle in line:
                    pid = line.split()[0]
                    subprocess.Popen(["kill", "-TERM", pid])
            GLib.timeout_add(1500, self._refresh)
        self._tray_show()
        self._confirm(S["dlg_stop_t"].format(name), S["dlg_stop_b"], on_confirm)

    def _push_tray_vms(self):
        if not self._indicator:
            return
        running = [vm["_name"] for vm in self.vms if vm.get("_running")]
        try:
            self._tray_proc.stdin.write(f"vms:{'|'.join(running)}\n")
            self._tray_proc.stdin.flush()
        except Exception:
            pass

    def _tray_quit(self):
        self._teardown_systray()
        for timeout_id in self._timeout_handlers:
            GLib.source_remove(timeout_id)
        self._timeout_handlers.clear()
        self.get_application().quit()

    def _teardown_systray(self):
        if self._indicator:
            try:
                self._tray_proc.stdin.write("quit\n")
                self._tray_proc.stdin.flush()
                self._tray_proc.wait(timeout=2)
            except Exception:
                try:
                    self._tray_proc.kill()
                except Exception:
                    pass
            self._indicator = None

    def _track(self, win):
        self._transients.append(win)
        win.connect('destroy', lambda w: self._transients.remove(w) if w in self._transients else None)

    def _tray_show(self):
        self.set_visible(True)
        self.present()
        for win in self._transients:
            if win.get_visible():
                win.present()

    def _tray_toggle(self, *_):
        if self.get_visible():
            self.hide()
        else:
            self._tray_show()

    def _on_tray_header_toggle(self, btn):
        val = "true" if btn.get_active() else "false"
        setconf("systray", val)
        self.conf["systray"] = val
        if btn.get_active():
            self._init_systray()
        else:
            self._teardown_systray()

    def _on_close_request(self, *args):
        if self._indicator and self.conf.get("systray") == "true":
            self.hide()
            return True
        self._teardown_systray()
        for timeout_id in self._timeout_handlers:
            GLib.source_remove(timeout_id)
        self._timeout_handlers.clear()
        self.get_application().quit()
        return False

    def _poll_running_state(self):
        """Check if any VM's running state changed - refresh only if so."""
        changed = False
        row = self.listbox.get_first_child()
        while row is not None:
            if hasattr(row, "vm"):
                was_running = row.vm.get("_running", False)
                now_running = is_running(row.vm["_name"])
                if was_running != now_running:
                    changed = True
                    break
            row = row.get_next_sibling()
        if changed:
            self._refresh()
        return True  # keep firing

    def _poll_copying(self):
        """Refresh every 2 seconds while a clone copy is in progress."""
        try:
            if list(Path(self.vms_dir).glob(".*.copying")):
                self._refresh()
        except Exception:
            pass
        return True

    def _poll_vms_dir(self):
        """Watch vms_dir for new/removed VMs, copies, and config changes."""
        try:
            mtime = os.stat(self.vms_dir).st_mtime
            if mtime != self._vms_dir_mtime:
                if self._vms_dir_mtime != 0:
                    self._refresh()
                    if self.current_vm:
                        self._show_panel(self.current_vm)
                self._vms_dir_mtime = mtime

            # detect config file edits (dir mtime doesn't change on file modify)
            conf_changed = False
            for p in Path(self.vms_dir).glob("*.conf"):
                m = p.stat().st_mtime
                if self._conf_mtimes.get(str(p)) != m:
                    conf_changed = True
                    self._conf_mtimes[str(p)] = m
            if conf_changed and self._vms_dir_mtime != 0:
                self._refresh()
                if self.current_vm:
                    self._show_panel(self.current_vm)
        except Exception:
            pass
        return True

