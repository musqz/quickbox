    def _run_with_progress(self, title, cmd_list, cwd=None, on_done=None,
                            total_bytes=0, watch_path=None):
        dlg = Gtk.Window(title=title)
        dlg.set_transient_for(self); self._track(dlg)
        _set_icon(dlg)
        dlg.set_modal(True)
        dlg.set_deletable(False)
        dlg.set_default_size(420, 180)
        dlg.set_size_request(340, 150)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_top(28); box.set_margin_bottom(24)
        box.set_margin_start(28); box.set_margin_end(28)
        box.set_valign(Gtk.Align.CENTER)

        title_lbl = Gtk.Label()
        title_lbl.set_markup(f'<span weight="bold" size="large">{title}</span>')
        title_lbl.set_halign(Gtk.Align.CENTER)
        box.append(title_lbl)

        progress = Gtk.ProgressBar()
        progress.set_show_text(False)
        box.append(progress)

        status_lbl = Gtk.Label(label=S["prog_wait"])
        status_lbl.set_halign(Gtk.Align.CENTER)
        status_lbl.add_css_class("dim-label")
        box.append(status_lbl)

        dlg.set_child(box)
        dlg.present()

        self._proc_running = True

        def _fmt_bytes(n):
            for unit in ("B", "KB", "MB", "GB", "TB"):
                if n < 1024 or unit == "TB":
                    return f"{n:.1f} {unit}" if unit != "B" else f"{n} B"
                n /= 1024

        if total_bytes > 0 and watch_path:
            initial_size = dir_size_bytes(watch_path)
            def _poll_progress():
                if not self._proc_running:
                    return False
                done = max(dir_size_bytes(watch_path) - initial_size, 0)
                frac = min(done / total_bytes, 0.99)
                progress.set_fraction(frac)
                status_lbl.set_text(f"{_fmt_bytes(done)} / {_fmt_bytes(total_bytes)}")
                return True
            GLib.timeout_add(500, _poll_progress)
        else:
            def _pulse():
                progress.pulse()
                return self._proc_running
            GLib.timeout_add(150, _pulse)

        def _run():
            try:
                proc = subprocess.run(cmd_list, cwd=cwd, capture_output=True, text=True)
                rc = proc.returncode
            except Exception:
                rc = 1

            self._proc_running = False

            if rc == 0:
                GLib.idle_add(progress.set_fraction, 1.0)
                GLib.idle_add(status_lbl.set_markup,
                    f'<span color="gray">{S["prog_done"]}</span>')
            else:
                GLib.idle_add(status_lbl.set_markup,
                    f'<span color="red">{S["prog_fail"]}</span>')

            def _finish():
                dlg.close()
                if on_done:
                    on_done(rc == 0)
            GLib.timeout_add(1200, _finish)

        threading.Thread(target=_run, daemon=True).start()

    def _pick_dir(self, title, start, callback):
        fc = Gtk.FileChooserNative(title=title,
                                   transient_for=self,
                                   action=Gtk.FileChooserAction.SELECT_FOLDER)
        initial = Gio.File.new_for_path(start)
        fc.set_current_folder(initial)
        def _on_response(chooser, response):
            if response == Gtk.ResponseType.ACCEPT:
                gfile = chooser.get_file()
                callback(gfile.get_path() if gfile else None)
            else:
                callback(None)
        fc.connect("response", _on_response)
        fc.show()

