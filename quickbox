    def _filter(self, row):
        if not self._search_text:
            return True
        return (self._search_text in row.vm["_pretty"].lower() or
                self._search_text in row.vm["_name"].lower())

    def _refresh_ssh_menu(self):
        while child := self._ssh_popover_box.get_first_child():
            self._ssh_popover_box.remove(child)

        ssh_vms = []
        for vm in self.vms:
            if vm["_running"]:
