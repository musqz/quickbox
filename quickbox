    def _parse_quickinst(self):
        """Parse distro list from ~/.config/quickbox/quickinst.csv (quickget --list-csv format)."""
        import csv as _csv
        p = Path.home() / ".config/quickbox/quickinst.csv"
        distros = []
        if not p.exists():
            return distros
        try:
            with open(p, encoding="utf-8", newline="") as f:
                for row in _csv.DictReader(f):
                    display = row.get("Display Name", "").strip()
                    os_id   = row.get("OS", "").strip()
                    release = row.get("Release", "").strip()
                    option  = row.get("Option", "").strip()
                    if not os_id or not release:
                        continue
                    suffix = (" " + option if option and option.lower() not in display.lower() else "")
                    name = display + " " + release + suffix
                    cmd  = "quickget " + os_id + " " + release + (" " + option if option else "")
                    distros.append((name, cmd))
        except Exception:
            pass
        return sorted(distros, key=lambda x: x[0].lower())

    def _get_distro_versions(self, distros, distro_name):
        """Get all available versions/editions for a distro name (first word match)."""
        # Extract base distro from display name — e.g. "Ubuntu 24.04 LTS" -> "ubuntu"
        first_word = distro_name.split()[0].lower()
        versions = []
        for name, cmd in distros:
            parts = cmd.split()  # quickget distro release edition
            if len(parts) >= 2 and parts[1].lower() == first_word:
                # version label = everything after distro name in display
                label = name
                versions.append((label, cmd))
        return versions

