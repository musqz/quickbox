    def _clone_vm(self, vm):
        import datetime
        date_str  = datetime.datetime.now().strftime("%Y%m%d")
        suggested = f"{vm['_name']}-{date_str}"

        win = Gtk.Window(title=S["clone_title"])
        win.set_transient_for(self)
        win.set_modal(True)
