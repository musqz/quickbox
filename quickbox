        format_btn.add_css_class("destructive-action")
        btn_row.append(format_btn)
        box.append(btn_row)
        win.set_child(box)

        def _on_format(b):
            size_gb = int(size_spin.get_value())
            layout = next((rb._layout_id for rb in radios if rb.get_active()), "blank")
            win.close()

            def on_confirm(yes):
                if not yes:
                    return
                disk_path = vm["_disk"] or str(Path(self.vms_dir) / vm["_name"] / "disk.qcow2")

                def _do_format():
                    import tempfile
                    tmp = tempfile.mktemp(suffix=".raw", dir=self.vms_dir)
                    try:
                        GLib.idle_add(notify, "quickbox-gui",
                                      S["ntf_fmt_start"].format(size_gb), "low")
                        subprocess.run(["qemu-img", "create", "-f", "raw", tmp, f"{size_gb}G"],
                                       check=True)
                        if layout == "gpt_esp_ext4":
                            subprocess.run(["parted", "-s", tmp,
                                "mklabel", "gpt",
                                "mkpart", "ESP", "fat32", "1MiB", "513MiB",
                                "set", "1", "esp", "on",
                                "mkpart", "primary", "ext4", "513MiB", "100%"],
                                check=True)
                        elif layout == "msdos_ext4":
                            subprocess.run(["parted", "-s", tmp,
                                "mklabel", "msdos",
                                "mkpart", "primary", "ext4", "1MiB", "100%"],
                                check=True)
                        elif layout == "msdos_fat32":
                            subprocess.run(["parted", "-s", tmp,
                                "mklabel", "msdos",
                                "mkpart", "primary", "fat32", "1MiB", "100%"],
                                check=True)
                        Path(disk_path).parent.mkdir(parents=True, exist_ok=True)
                        subprocess.run(["qemu-img", "convert", "-f", "raw", "-O", "qcow2",
                                         tmp, disk_path], check=True)
                        setconf("disk_size", f"{size_gb}G", vm["_conf"])
                        vm["disk_size"] = f"{size_gb}G"
                        GLib.idle_add(notify, "quickbox-gui",
                                      S["ntf_fmt_done"].format(layout, size_gb), "low")
                        GLib.idle_add(self._refresh)
                    except subprocess.CalledProcessError as e:
                        GLib.idle_add(self._warn, S["warn_fmt_fail_t"],
                                      S["warn_fmt_fail_b"].format(' '.join(str(x) for x in e.cmd)))
                    finally:
                        if Path(tmp).exists():
                            Path(tmp).unlink()

                self._run_with_progress(f"Formatting disk — {size_gb}GB {layout}", ["true"])
                threading.Thread(target=_do_format, daemon=True).start()

            self._confirm(
                S["dlg_fmt_t"],
                S["dlg_fmt_b"].format(size_gb, layout),
                on_confirm
            )

        format_btn.connect("clicked", _on_format)
        win.present()

