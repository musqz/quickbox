    def _refresh(self):
        while row := self.listbox.get_first_child():
            self.listbox.remove(row)
        self.vms = get_vms(self.vms_dir)
        for vm in self.vms:
            self.listbox.append(VMRow(vm))
        importing = any(vm.get("_copying") for vm in self.vms)
        self._any_importing = importing
        for b in self._hdr_action_btns:
            b.set_sensitive(not importing)
        n = len(self.vms)
        vms_str = S["status_vms_pl"].format(n) if n != 1 else S["status_vms"].format(n)
        self._status.set_markup(
            f'<span size="small">{self.vms_dir}  •  {vms_str}</span>')
        self._subtitle_lbl.set_label(self.vms_dir)
        # re-select
        if self.current_vm:
            name = self.current_vm["_name"]
            row = self.listbox.get_first_child()
            while row is not None:
                if hasattr(row, "vm") and row.vm["_name"] == name:
                    self.listbox.select_row(row)
                    self.current_vm = row.vm
                    break
                row = row.get_next_sibling()
        self._push_tray_vms()
        return False  # stop GLib.timeout_add

