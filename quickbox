def read_conf():
    conf = {}
    if CONFIG_FILE.exists():
        for line in CONFIG_FILE.read_text().splitlines():
            line = line.strip()
            if "=" in line and not line.startswith("#"):
                k, _, v = line.partition("=")
                conf[k.strip()] = v.strip().strip('"')
    conf.setdefault("vms_dir", str(Path.home() / "emu"))
    return conf


def setconf(key, value, filepath=None):
    """Safe conf writer - handles paths with slashes."""
    fp = Path(filepath) if filepath else CONFIG_FILE
    content = fp.read_text() if fp.exists() else ""
    lines = content.splitlines()
    updated = False
    for i, line in enumerate(lines):
        if line.startswith(f"{key}="):
            lines[i] = f"{key}={value}"
            updated = True
            break
    if not updated:
        lines.append(f"{key}={value}")
    fp.write_text("\n".join(lines) + "\n")


def remove_key(key, filepath):
    fp = Path(filepath)
    if not fp.exists():
        return
    lines = [l for l in fp.read_text().splitlines() if not l.startswith(f"{key}=")]
    fp.write_text("\n".join(lines) + "\n")


def read_vm_conf(path):
    vm = {}
    try:
        for line in Path(path).read_text().splitlines():
            line = line.strip()
            if "=" in line and not line.startswith("#"):
                k, _, v = line.partition("=")
                vm[k.strip()] = v.strip().strip('"')
    except Exception:
        pass
    return vm


def is_running(vmname):
    r = subprocess.run(["pgrep", "-f", f"name {vmname},process={vmname}"],
                       capture_output=True)
    return r.returncode == 0


def dir_size(path):
    try:
        r = subprocess.run(["du", "-sh", path], capture_output=True, text=True)
        return r.stdout.split()[0] if r.stdout.strip() else "?"
    except Exception:
        return "?"


def get_snapshots(disk_path):
    snaps = []
    try:
        r = subprocess.run(["qemu-img", "snapshot", "-l", disk_path],
                           capture_output=True, text=True)
        for line in r.stdout.splitlines()[2:]:
            parts = line.split()
            if len(parts) >= 2:
                snaps.append({"id": parts[0], "tag": parts[1]})
    except Exception:
        pass
    return snaps


def get_vms(vms_dir):
    vms = []
    for conf_path in sorted(glob.glob(f"{vms_dir}/*.conf")):
        vm = read_vm_conf(conf_path)
        vm["_conf"]    = conf_path
        vm["_name"]    = Path(conf_path).stem
        vm["_pretty"]  = vm.get("pretty", vm["_name"])
        vm["_running"] = is_running(vm["_name"])
        disk = vm.get("disk_img", "")
        vm["_disk"]    = str(Path(vms_dir) / disk) if disk else ""
        vm["_has_disk"] = Path(vm["_disk"]).exists() if vm["_disk"] else False
        vm["_size"]    = dir_size(str(Path(vms_dir) / vm["_name"]))
        vms.append(vm)
    return vms


