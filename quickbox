    def _launch_vm(self, vm, preview_disk=None):
        """
        Launch VM with proper boot/reboot handling.
        preview_disk: if set, boot from this path instead of the main disk
                      (used by Boot-from-snapshot — main disk is not modified).
        """
        vmname    = vm["_name"]
        vmdir     = str(Path(self.vms_dir) / vmname)
        conf_path = vm["_conf"]
        # preview_disk forces direct QEMU mode — quickemu can't use a custom disk path
        compat    = True if preview_disk else vm.get("compat_mode") == "true"
        boot      = vm.get("boot", "uefi")
        quiet     = vm.get("quiet_launch") == "true"
        disk_if   = vm.get("disk_if", "")
        net_dev   = vm.get("net_device", "e1000")
        disk_img  = vm.get("disk_img", "")
        iso       = "" if preview_disk else vm.get("iso", "")
        disk_path = preview_disk or (str(Path(self.vms_dir) / disk_img) if disk_img else "")
        iso_path  = str(Path(self.vms_dir) / iso) if iso else ""
        ram       = vm.get("ram", "4G")
        cpu_cores = vm.get("cpu_cores", "2")
        live_mode = vm.get("live_mode") == "true"
        headless  = vm.get("headless") == "true"
        
        # Create vmdir if needed
        Path(vmdir).mkdir(parents=True, exist_ok=True)

        # OVMF setup — persistent, never reset
        ovmf_vars = str(Path(vmdir) / "OVMF_VARS.fd")
        if boot == "uefi":
            # Create OVMF_VARS ONCE. Then leave it alone forever.
            # This allows EFI bootloader registration to persist across installs.
            if not Path(ovmf_vars).exists() and OVMF_VARS_TEMPLATE:
                shutil.copy(str(OVMF_VARS_TEMPLATE), ovmf_vars)

        # Ensure disk exists (skip in live_mode or preview_disk mode)
        if disk_path and not Path(disk_path).exists() and not live_mode and not preview_disk:
            disk_size = vm.get("disk_size", "32G")
            subprocess.run(["qemu-img", "create", "-f", "qcow2", disk_path, disk_size])

        # Ensure SSH config before launch
        self._ensure_ssh_config(vm)

        accel   = "kvm" if KVM_AVAILABLE else "tcg"

        if not quiet:
            notify("quickbox", S["ntf_launching"].format(vmname), "low")

        # Base QEMU args (all modes)
        base_args = [
            "qemu-system-x86_64",
            "-name", f"{vmname},process={vmname}",
            "-machine", f"q35,accel={accel}",
            "-cpu", "host" if KVM_AVAILABLE else "max",
            "-m", ram,
            "-smp", cpu_cores,
            "-vga", "std",
            "-display", "none" if headless else "gtk,zoom-to-fit=on",
            "-no-reboot",
        ]

        log = f"/tmp/qemu-{vmname}.log"
        ssh_port = vm.get("ssh_port", "2222")

        if compat:
            # PATH C: Special modes (EasyOS raw IMG, legacy boot, custom disk_if)
            # ──────────────────────────────────────────────────────────────────
            if disk_if:
                # EasyOS or other custom formats with disk_if (ide, ahci, etc)
                cmd = base_args + [
                    "-drive", f"format=qcow2,file={disk_path},if={disk_if}",
                    "-device", f"{net_dev},netdev=nic",
                    "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                ]
            # ──────────────────────────────────────────────────────────────────
            # PATH A+C: Raw IMG file (legacy or UEFI)
            # ──────────────────────────────────────────────────────────────────
            elif iso_path and iso_path.endswith((".img", ".IMG")):
                # Raw disk image — use as-is, no CDROM
                if boot == "uefi" and OVMF_CODE:
                    # UEFI + raw IMG
                    cmd = base_args + [
                        "-drive", f"if=pflash,format=raw,unit=0,file={OVMF_CODE},readonly=on",
                        "-drive", f"if=pflash,format=raw,unit=1,file={ovmf_vars}",
                        "-drive", f"format=raw,file={iso_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]
                else:
                    # Legacy + raw IMG
                    cmd = base_args + [
                        "-boot", "order=c",
                        "-drive", f"format=raw,file={iso_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]
            # ──────────────────────────────────────────────────────────────────
            # PATH A: ISO + Disk (install phase)
            # ──────────────────────────────────────────────────────────────────
            elif iso_path and Path(iso_path).exists():
                # Have both ISO and disk — installation phase
                if boot == "uefi" and OVMF_CODE:
                    # UEFI ISO install
                    # -boot order=d forces CDROM first during install
                    # Bootloader writes EFI entry to ovmf_vars.fd
                    # Post-install reboot: firmware finds entry, boots disk
                    cmd = base_args + [
                        "-boot", "order=d",
                        "-drive", f"if=pflash,format=raw,unit=0,file={OVMF_CODE},readonly=on",
                        "-drive", f"if=pflash,format=raw,unit=1,file={ovmf_vars}",
                        "-drive", f"media=cdrom,file={iso_path}",
                        "-drive", f"format=qcow2,file={disk_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]
                else:
                    # Legacy ISO install
                    cmd = base_args + [
                        "-boot", "order=d",
                        "-drive", f"media=cdrom,file={iso_path}",
                        "-drive", f"format=qcow2,file={disk_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]
            # ──────────────────────────────────────────────────────────────────
            # PATH B: Disk only (post-install)
            # ──────────────────────────────────────────────────────────────────
            else:
                # ISO removed or missing — post-install phase, boot from disk
                if boot == "uefi" and OVMF_CODE:
                    # UEFI disk boot
                    # ovmf_vars.fd has bootloader entry from install
                    # No -boot order override; firmware uses saved entry
                    cmd = base_args + [
                        "-drive", f"if=pflash,format=raw,unit=0,file={OVMF_CODE},readonly=on",
                        "-drive", f"if=pflash,format=raw,unit=1,file={ovmf_vars}",
                        "-drive", f"format=qcow2,file={disk_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]
                else:
                    # Legacy disk boot
                    cmd = base_args + [
                        "-boot", "order=c",
                        "-drive", f"format=qcow2,file={disk_path}",
                        "-device", f"{net_dev},netdev=nic",
                        "-netdev", f"user,hostname={vmname},hostfwd=tcp::{ssh_port}-:22,id=nic",
                    ]

        else:
            # Normal quickemu path (non-compat)
            cmd = ["quickemu", "--vm", conf_path]

        with open(log, "w") as logfile:
            subprocess.Popen(cmd, stdout=logfile, stderr=logfile)

        # Mark disk as potentially changed — cleared when a snapshot is applied
        if not preview_disk:
            setconf("snap_dirty", "true", conf_path)
            vm["snap_dirty"] = "true"

        GLib.timeout_add(3000, self._refresh)

    def _select_vm_by_name(self, name):
        row = self.listbox.get_first_child()
        while row is not None:
            if hasattr(row, "vm") and row.vm["_name"] == name:
                self.listbox.select_row(row)
                self.current_vm = row.vm
                self._show_panel(row.vm)
                return False
            row = row.get_next_sibling()
        return False

    def _stop_vm(self, vm):
        subprocess.Popen(["pkill", "-f", f"name {vm['_name']},process={vm['_name']}"])
        GLib.timeout_add(1500, self._refresh)

    # ── boot mode ──

    def _on_boot_changed(self, dropdown, _pspec, vm, boot_ids):
        idx = dropdown.get_selected()
        if 0 <= idx < len(boot_ids):
            val = boot_ids[idx]
            setconf("boot", val, vm["_conf"])
            vm["boot"] = val

    def _on_profile_changed(self, dropdown, _pspec, desc_label, vm, profile_ids):
        idx = dropdown.get_selected()
        if not (0 <= idx < len(profile_ids)):
            return
        pid = profile_ids[idx]
        profile = PROFILES.get(pid, PROFILES["standard"])
        desc_label.set_markup(f'<span size="small" color="gray">{profile["desc"]}</span>')
        setconf("vm_profile", pid, vm["_conf"])
        for key in _PROFILE_KEYS:
            remove_key(key, vm["_conf"])
        for key, val in profile["settings"].items():
            setconf(key, val, vm["_conf"])
        vm["vm_profile"] = pid
        for key in _PROFILE_KEYS:
            vm.pop(key, None)
        vm.update(profile["settings"])
        # Refresh panel so switches (e.g. compat_mode) reflect new profile state
        self._show_panel(vm)

    def _reset_default_profiles(self):
        global PROFILES, _PROFILE_KEYS
        write_default_profiles(overwrite=True)
        PROFILES = load_profiles()
        _PROFILE_KEYS = {key for p in PROFILES.values() for key in p["settings"]}
        notify("quickbox", S["ntf_prof_reset"], "low")

    # ── snapshots ──

    def _snap_create(self, vm):
        tag = self._snap_entry.get_text().strip()
        if not tag:
            return
        if vm["_running"]:
            self._warn(S["vm_running"], S["warn_snap_running_b"])
            return
        disk = vm["_disk"]
        if not Path(disk).exists():
            self._warn(S["warn_no_disk_t"], S["warn_no_disk_b"])
            return
        existing = [s["tag"] for s in get_snapshots(disk)]
        if tag in existing:
            self._warn(S["warn_dup_snap_t"], S["warn_dup_snap_b"].format(tag))
            return
        result = subprocess.run(
            ["qemu-img", "snapshot", "-c", tag, disk],
            capture_output=True, text=True
        )
        if result.returncode == 0:
            self._snap_entry.set_text("")
            notify("quickbox", S["ntf_snap_created"].format(tag), "low")
            self._show_panel(vm)
        else:
            self._warn(S["warn_snap_fail_t"], result.stderr or "qemu-img returned an error.")

    def _snap_apply(self, vm, tag):
        import datetime
        auto_tag = f"pre-apply-{datetime.datetime.now().strftime('%Y%m%d-%H%M')}"

        win = Gtk.Window(title=S["dlg_snap_apply_t"].format(tag))
        win.set_transient_for(self)
        win.set_modal(True)
        win.set_default_size(460, 200)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_top(20); box.set_margin_bottom(16)
        box.set_margin_start(20); box.set_margin_end(20)

        warn_lbl = Gtk.Label(label=S["dlg_snap_apply_b"])
        warn_lbl.set_halign(Gtk.Align.START)
        warn_lbl.set_wrap(True)
        box.append(warn_lbl)

        # Backup is only needed if the disk changed since the last apply.
        # snap_dirty is set on VM launch and cleared on successful apply.
        disk_unchanged = (vm.get("current_snap") == tag and
                          vm.get("snap_dirty") != "true")

        save_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        if disk_unchanged:
            chk = Gtk.CheckButton(label=S["snap_autosave_skip"])
            chk.set_active(False)
            chk.set_sensitive(False)
            save_row.append(chk)
        else:
            chk = Gtk.CheckButton(label=S["snap_autosave_chk"])
            chk.set_active(True)
            name_entry = Gtk.Entry()
            name_entry.set_text(auto_tag)
            name_entry.set_hexpand(True)
            chk.connect("toggled", lambda c: name_entry.set_sensitive(c.get_active()))
            save_row.append(chk)
            save_row.append(name_entry)
        box.append(save_row)

        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        _sp = Gtk.Box(); _sp.set_hexpand(True)
        btn_row.append(_sp)
        cancel_btn = Gtk.Button(label=S["btn_cancel"])
        cancel_btn.connect("clicked", lambda b: win.close())
        btn_row.append(cancel_btn)
        apply_btn = Gtk.Button(label=S["snap_apply"])
        apply_btn.add_css_class("destructive-action")
        btn_row.append(apply_btn)
        box.append(btn_row)
        win.set_child(box)

        def _do_apply(b):
            save_first = chk.get_active()
            save_name = name_entry.get_text().strip() if (save_first and not disk_unchanged) else auto_tag
            win.close()

            def _run():
                if save_first:
                    r = subprocess.run(
                        ["qemu-img", "snapshot", "-c", save_name, vm["_disk"]],
                        capture_output=True, text=True)
                    if r.returncode != 0:
                        GLib.idle_add(self._warn, S["warn_snap_fail_t"],
                                      f"Auto-save failed: {r.stderr}")
                        return
                    GLib.idle_add(notify, "quickbox",
                                  S["snap_autosave_done"].format(save_name), "low")

                r = subprocess.run(
                    ["qemu-img", "snapshot", "-a", tag, vm["_disk"]],
                    capture_output=True, text=True)
                if r.returncode != 0:
                    GLib.idle_add(self._warn, S["warn_snap_fail_t"],
                                  r.stderr or "qemu-img returned an error.")
                    return
                setconf("current_snap", tag, vm["_conf"])
                vm["current_snap"] = tag
                remove_key("snap_dirty", vm["_conf"])
                vm.pop("snap_dirty", None)
                GLib.idle_add(notify, "quickbox", S["ntf_snap_applied"].format(tag))
                GLib.idle_add(self._show_panel, vm)
                GLib.timeout_add(500, self._refresh)

            threading.Thread(target=_run, daemon=True).start()

        apply_btn.connect("clicked", _do_apply)
        win.present()



    def _snap_delete(self, vm, tag):
        def on_confirm(yes):
            if not yes:
                return
            subprocess.run(["qemu-img", "snapshot", "-d", tag, vm["_disk"]])
            if vm.get("current_snap") == tag:
                remove_key("current_snap", vm["_conf"])
                vm.pop("current_snap", None)
            self._show_panel(vm)
        self._confirm(S["dlg_snap_del_t"].format(tag), S["dlg_snap_del_b"], on_confirm)

