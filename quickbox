        sel_box.append(none_btn)
        pb.append(sel_box)

        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroll.set_vexpand(True)
        list_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        scroll.set_child(list_box)
        pb.append(scroll)

        checks = []
        for vm in vms:
            running_tag = S["mig_running_tag"] if vm["_running"] else ""
            cb = Gtk.CheckButton(label=f"{vm['_pretty']}  ({vm['_size']}){running_tag}")
            cb._vm = vm
            cb.set_sensitive(not vm["_running"])
            cb.set_tooltip_text(S["mig_stop_tt"] if vm["_running"] else vm["_name"])
            list_box.append(cb)
            checks.append(cb)

        all_btn.connect("clicked",
            lambda b: [c.set_active(True) for c in checks if c.get_sensitive()])
        none_btn.connect("clicked",
            lambda b: [c.set_active(False) for c in checks])

        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_row.set_margin_top(8); btn_row.set_margin_bottom(8)
        btn_row.set_margin_start(14); btn_row.set_margin_end(14)
        _sp = Gtk.Box(); _sp.set_hexpand(True)
        btn_row.append(_sp)
        cancel_pick = Gtk.Button(label=S["btn_cancel"])
        cancel_pick.connect("clicked", lambda b: pick.close())
        btn_row.append(cancel_pick)
        next_pick = Gtk.Button(label=S["btn_next"])
        next_pick.add_css_class("suggested-action")
        btn_row.append(next_pick)
        pick_outer.append(btn_row)
        pick.set_child(pick_outer)

        def _on_next_pick(b):
            selected = [c._vm for c in checks if c.get_active() and c.get_sensitive()]
            pick.close()
            if not selected:
                return

            def _on_folder(path):
                if not path:
                    return
                newdir = str(Path(path) / "emu")
                if newdir == self.vms_dir:
                    self._warn(S["warn_same_loc_t"], S["warn_same_loc_b"])
                    return
                names = "\n  • ".join(v["_pretty"] for v in selected)
                def on_confirm(yes):
                    if not yes:
                        return
                    Path(newdir).mkdir(parents=True, exist_ok=True)
                    rsync_cmd = ["rsync", "-a", "--info=progress2"]
                    for vm in selected:
                        vm_dir = str(Path(self.vms_dir) / vm["_name"])
                        if Path(vm_dir).exists():
                            rsync_cmd.append(vm_dir)
                        rsync_cmd.append(vm["_conf"])
                    rsync_cmd.append(f"{newdir}/")

                    def _migration_done(ok):
                        if not ok:
                            self._warn(S["warn_mig_fail_t"], S["warn_mig_fail_b"])
                            return
                        def on_danger(yes):
                            if yes:
                                for vm in selected:
                                    vm_dir = Path(self.vms_dir) / vm["_name"]
                                    if vm_dir.exists():
                                        shutil.rmtree(str(vm_dir))
                                    if Path(vm["_conf"]).exists():
                                        Path(vm["_conf"]).unlink()
                            self._refresh()
                            self._refresh_loc_list(dlg)
                        self._confirm_danger(
                            S["dlg_danger_t"],
                            S["dlg_danger_b"].format(len(selected), self.vms_dir),
                            on_danger
                        )

                    self._run_with_progress(
                        f"Migrating {len(selected)} VM(s)",
                        rsync_cmd,
                        on_done=_migration_done
                    )
                self._confirm(
                    S["dlg_migrate_t"],
                    S["dlg_migrate_b"].format(len(selected), newdir, names),
                    on_confirm
                )

            self._pick_dir(S["btn_pick_dest"], str(Path.home()), _on_folder)

        next_pick.connect("clicked", _on_next_pick)
        pick.present()

    def _do_add_loc(self, dlg):
        def _on_dir(loc):
            if not loc:
                return
            conf = read_conf()
            for i in range(1, 6):
                if not conf.get(f"vms_dir_{i}"):
                    setconf(f"vms_dir_{i}", loc)
                    self._refresh_loc_list(dlg)
                    return
            self._warn(S["warn_list_full_t"], S["warn_list_full_b"])
        self._pick_dir(S["btn_add_switch"], str(Path.home()), _on_dir)

