def get_ssh_user(guest_os):
    """Auto-detect SSH user by distro."""
    guest_os = guest_os.lower()
    if any(x in guest_os for x in ["ubuntu", "debian", "mint", "elementary"]):
        return "ubuntu"
    return "root"


def get_next_ssh_port(vms_dir, vmname):
    """Assign unique SSH port 2222-2299 per VM, stored in .conf."""
    vms = get_vms(vms_dir)
    used_ports = set()
    for vm in vms:
        if vm["_name"] != vmname:
            port = vm.get("ssh_port", "")
            if port:
                try:
                    used_ports.add(int(port))
                except ValueError:
                    pass
    for port in range(2222, 2300):
        if port not in used_ports:
            return str(port)
    return "2222"


